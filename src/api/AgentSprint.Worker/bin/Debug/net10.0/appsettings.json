{
  "Worker": {
    "WorkerId": "worker-1",
    "WorkerName": "agentsprint-codex-worker-1",
    "ProjectId": "",
    "ProjectCode": "",
    "WorkspaceRoot": "/workspaces",
    "RunsRoot": "/runs",
    "CodexHome": "/codex-home",
    "PollIntervalSeconds": 15,
    "IdleMaxIntervalSeconds": 180,
    "MaxRunMinutes": 60,
    "CodexIdleTimeoutSeconds": 90,
    "CodexExecutable": "codex",
    "SandboxMode": "workspace-write",
    "RunSmokeOnStartup": false,
    "SmokePrompt": "你好"
  },
  "AgentSprint": {
    "ApiBaseUrl": "http://api:5000",
    "AgentToken": ""
  },
  "AkkaSettings": {
    "Enabled": true,
    "SystemName": "agentsprint-worker",
    "Host": "0.0.0.0",
    "Port": 0,
    "Roles": [ "agentsprint-worker" ],
    "AskTimeoutSeconds": 10,
    "ShutdownTimeoutSeconds": 30,
    "Domains": {
      "AgentSprintWorker": {
        "Role": "agentsprint-worker",
        "ActorNamePrefix": "agentsprint-worker",
        "AllowCrossDomainMessages": true
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Air.Cloud.Modules.Akka": "Information",
      "Akka": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
